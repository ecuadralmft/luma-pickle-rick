# Ignore everything by default
*

# Allow project files
!.gitignore
!pickle-rick-v2-spec.md

# Allow .kiro project files
!.kiro/
!.kiro/README-pickle-rick.md
!.kiro/agents/
!.kiro/agents/*.json
!.kiro/prompts/
!.kiro/prompts/*.txt
!.kiro/hooks/
!.kiro/hooks/*.sh

# Allow settings scaffolding (example only, not user-specific configs)
!.kiro/settings/
!.kiro/settings/mcp.json.example

# Allow launcher
!bin/
!bin/pickle-rick

# Conductor state stays local (not pushed)
# conductor/
.gitpulse/
